{
  "columns": [
    "ticker-view",
    "close",
    "type",
    "typespecs",
    "pricescale",
    "minmov",
    "fractional",
    "minmove2",
    "currency",
    "change",
    "volume",
    "relative_volume_10d_calc",
    "market_cap_basic",
    "fundamental_currency_code",
    "price_earnings_ttm",
    "earnings_per_share_diluted_ttm",
    "earnings_per_share_diluted_yoy_growth_ttm",
    "dividends_yield_current",
    "sector.tr",
    "market",
    "sector",
    "AnalystRating",
    "AnalystRating.tr"
  ],
  "filter": [
    { "left": "close", "operation": "egreater", "right": 50 },
    { "left": "market_cap_basic", "operation": "egreater", "right": 10000000000 },
    { "left": "Perf.W", "operation": "greater", "right": -1 },
    { "left": "Value.Traded|1M", "operation": "greater", "right": 50000000 },
    { "left": "Perf.1M", "operation": "greater", "right": 5 },
    { "left": "RSI5|1M", "operation": "egreater", "right": 60 },
    { "left": "RSI5|1W", "operation": "greater", "right": 56 },
    { "left": "High.1M", "operation": "eless", "right": "high" },
    { "left": "is_primary", "operation": "equal", "right": true }
  ],
  "ignore_unknown_fields": false,
  "options": { "lang": "en" },
  "range": [0, 200],
  "sort": { "sortBy": "close", "sortOrder": "desc" },
  "symbols": {},
  "markets": ["india"],
  "filter2": {
    "operator": "and",
    "operands": [
      {
        "operation": {
          "operator": "or",
          "operands": [
            {
              "operation": {
                "operator": "and",
                "operands": [
                  { "expression": { "left": "type", "operation": "equal", "right": "stock" } },
                  { "expression": { "left": "typespecs", "operation": "has", "right": ["common"] } }
                ]
              }
            },
            {
              "operation": {
                "operator": "and",
                "operands": [
                  { "expression": { "left": "type", "operation": "equal", "right": "stock" } },
                  { "expression": { "left": "typespecs", "operation": "has", "right": ["preferred"] } }
                ]
              }
            },
            {
              "operation": {
                "operator": "and",
                "operands": [{ "expression": { "left": "type", "operation": "equal", "right": "dr" } }]
              }
            },
            {
              "operation": {
                "operator": "and",
                "operands": [
                  { "expression": { "left": "type", "operation": "equal", "right": "fund" } },
                  {
                    "expression": {
                      "left": "typespecs",
                      "operation": "has_none_of",
                      "right": ["etf", "mutual", "closedend"]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "expression": {
          "left": "typespecs",
          "operation": "has_none_of",
          "right": ["pre-ipo"]
        }
      }
    ]
  }
}
